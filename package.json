{
  "name": "astro-theme-aither",
  "private": true,
  "type": "module",
  "version": "2026.03.20",
  "description": "An AI-native Astro starter built around beautiful text.",
  "license": "MIT",
  "homepage": "https://github.com/justinhuangcode/astro-theme-aither",
  "repository": {
    "type": "git",
    "url": "https://github.com/justinhuangcode/astro-theme-aither.git"
  },
  "bugs": {
    "url": "https://github.com/justinhuangcode/astro-theme-aither/issues"
  },
  "engines": {
    "node": "^20.19.1 || >=22.12.0",
    "pnpm": "10.32.1"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "check:post-coverage": "node ./scripts/check-post-coverage.mjs",
    "build": "astro build",
    "smoke:markdown": "node ./scripts/smoke-markdown-rendering.mjs",
    "smoke:package": "node ./scripts/smoke-aither-package.mjs",
    "pack:astro-package": "pnpm --dir packages/aither-astro pack --dry-run",
    "smoke:agent-protocol": "node ./scripts/smoke-agent-protocol.mjs",
    "smoke": "pnpm build && pnpm smoke:package && pnpm smoke:markdown && pnpm pack:astro-package && pnpm smoke:agent-protocol",
    "upgrade:diff": "node ./scripts/release-diff.mjs",
    "preview": "astro preview",
    "validate": "pnpm check && pnpm check:post-coverage && pnpm smoke",
    "astro": "astro"
  },
  "dependencies": {
    "@aither/astro": "workspace:^2026.3.20",
    "@astrojs/cloudflare": "^13.1.1",
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/react": "^5.0.0",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@fontsource/bricolage-grotesque": "^5.1.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.8",
    "astro": "^6.0.4",
    "katex": "^0.16.40",
    "markmap-lib": "^0.18.12",
    "markmap-view": "^0.18.12",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "satori": "^0.25.0",
    "tailwindcss": "^4.1.8",
    "tw-animate-css": "^1.3.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@resvg/resvg-js",
      "workerd"
    ]
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.8.3",
    "wrangler": "^4.75.0"
  }
}
