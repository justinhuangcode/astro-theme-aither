---
import { siteConfig } from '@/config/site';
import {
  defaultLocale,
  getMessages,
  htmlLangs,
  locales,
  stripLocalePrefix,
  type Locale,
} from '@/i18n';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  image?: string;
  bodyClass?: string;
}

const {
  locale,
  title,
  description,
  image,
  bodyClass = '',
} = Astro.props;

const m = getMessages(locale);
const photosConfig = siteConfig.photosGallery ?? {};
const indexName = m.galleryPage.name;
const icon = photosConfig.icon || photosConfig.logo || '/author-avatar.svg';
const appleIcon = photosConfig.appleIcon || icon;
const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).href;
const cleanPath = stripLocalePrefix(Astro.url.pathname);
const alternateUrls = locales.map((l) => ({
  hreflang: htmlLangs[l],
  href: new URL(l === defaultLocale ? cleanPath : `/${l}${cleanPath}`, siteConfig.url).href,
}));
const shareImage = image ? new URL(image, siteConfig.url).href : undefined;
const shareImageType = image?.endsWith('.webp') ? 'image/webp' : image?.endsWith('.png') ? 'image/png' : 'image/jpeg';
---

<!DOCTYPE html>
<html lang={htmlLangs[locale]}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="content-type" content={`text/html; charset=utf-8`} />
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {
      alternateUrls.map(({ hreflang, href }) => (
        <link rel="alternate" hreflang={hreflang} href={href} />
      ))
    }
    <link rel="icon" href={icon} />
    <link rel="bookmark" href={appleIcon} />
    <link rel="apple-touch-icon" href={appleIcon} />
    <link rel="apple-touch-icon-precomposed" sizes="180x180" href={appleIcon} />
    <meta name="apple-mobile-web-app-title" content={indexName} />
    {
      shareImage && (
        <>
          <meta property="og:title" content={title} />
          <meta property="og:description" content={description} />
          <meta property="og:url" content={canonicalUrl} />
          <meta property="og:image" content={shareImage} />
          <meta property="og:image:secure_url" content={shareImage} />
          <meta property="og:image:type" content={shareImageType} />
          <meta property="og:site_name" content={indexName} />
          <meta property="og:type" content="website" />
          <meta name="twitter:card" content="summary_large_image" />
          <meta name="twitter:title" content={title} />
          <meta name="twitter:description" content={description} />
          <meta name="twitter:image" content={shareImage} />
        </>
      )
    }
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
