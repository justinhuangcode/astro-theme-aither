---
import BlogPagination from '@/components/BlogPagination.astro';
import { siteConfig } from '@/config/site';
import { formatDate } from '@/lib/formatter';
import { getLocalizedPath, getMessages, type Locale } from '@/i18n';
import type { GalleryEntry } from '@/lib/gallery';
import Layout from '@/layouts/Layout.astro';

interface Props {
  locale: Locale;
  entries: GalleryEntry[];
  categories: string[];
  currentPage: number;
  totalPages: number;
}

const { locale, entries, categories, currentPage, totalPages } = Astro.props;
const m = getMessages(locale);
const pageTitle = `${m.galleryPage.name} | ${siteConfig.name}`;
const pageDescription = m.galleryPage.description;
const pageBasePath = getLocalizedPath('/photos', locale);
const heroImage =
  entries[0]?.data.cover ??
  entries[0]?.data.images[0] ??
  siteConfig.photosGallery?.ogImage ??
  siteConfig.ogImage;
const authorAvatar = siteConfig.author.avatar || '/author-avatar.svg';

function getEntryCover(entry: GalleryEntry) {
  return entry.data.cover ?? entry.data.images[0];
}

function getEntryImages(entry: GalleryEntry) {
  return entry.data.images.length > 0 ? entry.data.images : [getEntryCover(entry)];
}

const lightboxEntries = entries.map((entry) => ({
  title: entry.data.title,
  description: entry.data.description ?? '',
  device: entry.data.device ?? '',
  location: entry.data.location ?? '',
  date: formatDate(entry.data.date),
  category: entry.data.category ?? '',
  tags: entry.data.tags ?? [],
  images: getEntryImages(entry),
}));
---

<Layout title={pageTitle} description={pageDescription} image={heroImage}>
  <section class="photos-native-page" data-photos-root>
    <div class="photos-stage">
      {
        entries.length > 0 ? (
          <div class="photos-grid" role="list">
            {
              entries.map((entry, entryIndex) => (
                <article class="photo-thumb" role="listitem">
                  <button
                    class="photo-thumb-button"
                    type="button"
                    data-lightbox-entry={String(entryIndex)}
                    aria-label={entry.data.title}
                  >
                    <img
                      class="photo-thumb-image"
                      src={getEntryCover(entry)}
                      alt={entry.data.title}
                      loading={entryIndex === 0 ? 'eager' : 'lazy'}
                      decoding="async"
                    />
                    <span class="photo-thumb-overlay" aria-hidden="true"></span>
                    <span class="photo-thumb-copy">
                      <span class="photo-thumb-title">{entry.data.title}</span>
                    </span>
                  </button>
                </article>
              ))
            }
          </div>
        ) : (
          <section class="photos-empty">
            <h1>{m.galleryPage.emptyTitle}</h1>
            <p>{m.galleryPage.emptyDescription}</p>
          </section>
        )
      }

      {totalPages > 1 && <BlogPagination currentPage={currentPage} totalPages={totalPages} basePath={pageBasePath} />}
    </div>

    <footer class="photos-toolbar" aria-label={m.galleryPage.bottomToolbarLabel}>
      <div class="photos-toolbar-brand">
        <img class="photos-toolbar-avatar" src={authorAvatar} alt={siteConfig.author.name} />
        <div class="photos-toolbar-copy">
          <strong>{m.galleryPage.embeddedToolbarName}</strong>
        </div>
      </div>

      <div class="photos-toolbar-actions">
        <details class="photos-toolbar-menu">
          <summary>{m.galleryPage.categoriesLabel}</summary>
          <div class="photos-toolbar-menu-panel">
            <span class="photos-toolbar-menu-item is-active">{m.galleryPage.allLabel}</span>
            {
              categories.map((category) => (
                <span class="photos-toolbar-menu-item">{category}</span>
              ))
            }
          </div>
        </details>

        <button
          type="button"
          class="photos-toolbar-icon-button"
          data-photos-fullscreen
          aria-label={m.galleryPage.fullscreen}
          title={m.galleryPage.fullscreen}
        >
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="15 3 21 3 21 9"></polyline>
            <polyline points="9 21 3 21 3 15"></polyline>
            <line x1="21" y1="3" x2="14" y2="10"></line>
            <line x1="3" y1="21" x2="10" y2="14"></line>
          </svg>
        </button>
      </div>
    </footer>
  </section>

  <dialog class="photos-lightbox" data-photos-lightbox>
    <div class="photos-lightbox-frame">
      <button type="button" class="photos-lightbox-close" data-photos-lightbox-close aria-label="Close">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <button type="button" class="photos-lightbox-nav photos-lightbox-nav-prev" data-photos-lightbox-prev aria-label="Previous">
        <svg viewBox="0 0 24 24" width="44" height="44" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button type="button" class="photos-lightbox-nav photos-lightbox-nav-next" data-photos-lightbox-next aria-label="Next">
        <svg viewBox="0 0 24 24" width="44" height="44" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
      <figure class="photos-lightbox-figure">
        <img class="photos-lightbox-image" data-photos-lightbox-image alt="" />
        <figcaption class="photos-lightbox-caption">
          <h2 class="photos-lightbox-title" data-photos-lightbox-title></h2>
          <p class="photos-lightbox-description" data-photos-lightbox-description hidden></p>
          <div class="photos-lightbox-meta" data-photos-lightbox-meta hidden>
            <span class="photos-lightbox-meta-item" data-photos-lightbox-device hidden></span>
            <span class="photos-lightbox-meta-item" data-photos-lightbox-location hidden></span>
            <span class="photos-lightbox-meta-item" data-photos-lightbox-date hidden></span>
          </div>
          <div class="photos-lightbox-tags" data-photos-lightbox-tags hidden>
            <span class="photos-lightbox-category" data-photos-lightbox-category hidden></span>
            <span class="photos-lightbox-taglist" data-photos-lightbox-taglist hidden></span>
          </div>
          <div class="photos-lightbox-dots" data-photos-lightbox-dots hidden></div>
        </figcaption>
      </figure>
    </div>
  </dialog>

  <script is:inline define:vars={{ lightboxEntries, fullscreenLabel: m.galleryPage.fullscreen, exitFullscreenLabel: m.galleryPage.exitFullscreen }}>
    const pageRoot = document.querySelector('[data-photos-root]');
    const fullscreenButton = document.querySelector('[data-photos-fullscreen]');
    const lightbox = document.querySelector('[data-photos-lightbox]');
    const lightboxImage = lightbox?.querySelector('[data-photos-lightbox-image]');
    const lightboxTitle = lightbox?.querySelector('[data-photos-lightbox-title]');
    const lightboxDescription = lightbox?.querySelector('[data-photos-lightbox-description]');
    const lightboxMeta = lightbox?.querySelector('[data-photos-lightbox-meta]');
    const lightboxDevice = lightbox?.querySelector('[data-photos-lightbox-device]');
    const lightboxLocation = lightbox?.querySelector('[data-photos-lightbox-location]');
    const lightboxDate = lightbox?.querySelector('[data-photos-lightbox-date]');
    const lightboxTags = lightbox?.querySelector('[data-photos-lightbox-tags]');
    const lightboxCategory = lightbox?.querySelector('[data-photos-lightbox-category]');
    const lightboxTaglist = lightbox?.querySelector('[data-photos-lightbox-taglist]');
    const lightboxDots = lightbox?.querySelector('[data-photos-lightbox-dots]');
    const lightboxPrev = lightbox?.querySelector('[data-photos-lightbox-prev]');
    const lightboxNext = lightbox?.querySelector('[data-photos-lightbox-next]');
    const lightboxClose = lightbox?.querySelector('[data-photos-lightbox-close]');
    const entryButtons = Array.from(document.querySelectorAll('[data-lightbox-entry]'));

    let activeEntryIndex = 0;
    let activeImageIndex = 0;

    const syncFullscreenButton = () => {
      if (!fullscreenButton || !pageRoot) return;
      const isFullscreen = document.fullscreenElement === pageRoot;
      fullscreenButton.setAttribute('aria-label', isFullscreen ? exitFullscreenLabel : fullscreenLabel);
      fullscreenButton.setAttribute('title', isFullscreen ? exitFullscreenLabel : fullscreenLabel);
    };

    const renderLightbox = () => {
      if (!lightboxImage || !lightboxTitle) return;
      const entry = lightboxEntries[activeEntryIndex];
      const src = entry.images[activeImageIndex];
      lightboxImage.src = src;
      lightboxImage.alt = entry.title;
      lightboxTitle.textContent = entry.title;

      if (lightboxDescription instanceof HTMLElement) {
        lightboxDescription.hidden = !entry.description;
        lightboxDescription.textContent = entry.description;
      }

      const hasDevice = Boolean(entry.device);
      const hasLocation = Boolean(entry.location);
      const hasDate = Boolean(entry.date);

      if (lightboxDevice instanceof HTMLElement) {
        lightboxDevice.hidden = !hasDevice;
        lightboxDevice.textContent = entry.device;
      }

      if (lightboxLocation instanceof HTMLElement) {
        lightboxLocation.hidden = !hasLocation;
        lightboxLocation.textContent = entry.location;
      }

      if (lightboxDate instanceof HTMLElement) {
        lightboxDate.hidden = !hasDate;
        lightboxDate.textContent = entry.date;
      }

      if (lightboxMeta instanceof HTMLElement) {
        lightboxMeta.hidden = !(hasDevice || hasLocation || hasDate);
      }

      const hasCategory = Boolean(entry.category);
      const hasTags = Array.isArray(entry.tags) && entry.tags.length > 0;

      if (lightboxCategory instanceof HTMLElement) {
        lightboxCategory.hidden = !hasCategory;
        lightboxCategory.textContent = entry.category;
      }

      if (lightboxTaglist instanceof HTMLElement) {
        lightboxTaglist.hidden = !hasTags;
        lightboxTaglist.textContent = entry.tags.join(' · ');
      }

      if (lightboxTags instanceof HTMLElement) {
        lightboxTags.hidden = !(hasCategory || hasTags);
      }

      const hasMultiple = entry.images.length > 1;
      if (lightboxPrev instanceof HTMLButtonElement) {
        lightboxPrev.disabled = false;
        lightboxPrev.hidden = false;
      }
      if (lightboxNext instanceof HTMLButtonElement) {
        lightboxNext.disabled = false;
        lightboxNext.hidden = false;
      }
      if (lightboxDots instanceof HTMLElement) {
        lightboxDots.hidden = !hasMultiple;
        if (hasMultiple) {
          lightboxDots.innerHTML = entry.images
            .map(
              (_, index) =>
                `<button type="button" class="photos-lightbox-dot${index === activeImageIndex ? ' is-active' : ''}" data-photos-lightbox-dot="${index}" aria-label="Image ${index + 1}"></button>`,
            )
            .join('');
        } else {
          lightboxDots.innerHTML = '';
        }
      }
    };

    const openLightbox = (entryIndex, imageIndex = 0) => {
      if (!(lightbox instanceof HTMLDialogElement)) return;
      activeEntryIndex = entryIndex;
      activeImageIndex = imageIndex;
      renderLightbox();
      lightbox.showModal();
    };

    const closeLightbox = () => {
      if (lightbox instanceof HTMLDialogElement && lightbox.open) {
        lightbox.close();
      }
    };

    const stepLightbox = (delta) => {
      const totalEntries = lightboxEntries.length;
      if (totalEntries === 0) return;

      if (delta > 0) {
        const entry = lightboxEntries[activeEntryIndex];
        if (activeImageIndex < entry.images.length - 1) {
          activeImageIndex += 1;
        } else {
          activeEntryIndex = (activeEntryIndex + 1) % totalEntries;
          activeImageIndex = 0;
        }
      } else {
        if (activeImageIndex > 0) {
          activeImageIndex -= 1;
        } else {
          activeEntryIndex = (activeEntryIndex - 1 + totalEntries) % totalEntries;
          activeImageIndex = Math.max(0, lightboxEntries[activeEntryIndex].images.length - 1);
        }
      }

      renderLightbox();
    };

    entryButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const entryIndex = Number(button.getAttribute('data-lightbox-entry') || '0');
        openLightbox(entryIndex);
      });
    });

    fullscreenButton?.addEventListener('click', async () => {
      if (!pageRoot) return;
      if (document.fullscreenElement === pageRoot) {
        await document.exitFullscreen();
      } else {
        await pageRoot.requestFullscreen();
      }
    });

    document.addEventListener('fullscreenchange', syncFullscreenButton);
    lightboxPrev?.addEventListener('click', () => stepLightbox(-1));
    lightboxNext?.addEventListener('click', () => stepLightbox(1));
    lightboxClose?.addEventListener('click', closeLightbox);
    lightboxDots?.addEventListener('click', (event) => {
      const dot = event.target.closest('[data-photos-lightbox-dot]');
      if (!(dot instanceof HTMLElement)) return;
      const nextIndex = Number(dot.dataset.photosLightboxDot || '0');
      if (Number.isNaN(nextIndex)) return;
      activeImageIndex = nextIndex;
      renderLightbox();
    });
    lightbox?.addEventListener('click', (event) => {
      const dialog = event.currentTarget;
      if (event.target === dialog) closeLightbox();
    });
    lightbox?.addEventListener(
      'wheel',
      (event) => {
        if (!(lightbox instanceof HTMLDialogElement) || !lightbox.open) return;
        event.preventDefault();
        stepLightbox(event.deltaY > 0 ? 1 : -1);
      },
      { passive: false },
    );
    lightbox?.addEventListener('cancel', (event) => {
      event.preventDefault();
      closeLightbox();
    });

    document.addEventListener('keydown', (event) => {
      if (!(lightbox instanceof HTMLDialogElement) || !lightbox.open) return;
      if (event.key === 'Escape') {
        closeLightbox();
        return;
      }
      if (event.key === 'ArrowLeft' || event.key === ' ') stepLightbox(-1);
      if (event.key === 'ArrowRight') stepLightbox(1);
    });

    syncFullscreenButton();
  </script>
</Layout>

<style>
  .photos-native-page {
    min-height: calc(100vh - 59px);
    background: #181818;
    color: rgba(255, 255, 255, 0.94);
    position: relative;
    padding-bottom: 6rem;
  }

  .photos-stage {
    min-height: calc(100vh - 59px);
    padding: 0 0 2rem;
  }

  .photos-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    align-items: start;
  }

  .photo-thumb {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border-radius: 0;
  }

  .photo-thumb-button {
    appearance: none;
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
    cursor: zoom-in;
    text-align: left;
  }

  .photo-thumb-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .photo-thumb-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10, 17, 25, 0.54) 5%, rgba(10, 17, 25, 0) 36%);
    pointer-events: none;
  }

  .photo-thumb-copy {
    position: absolute;
    inset-inline: 1rem;
    bottom: 1rem;
    z-index: 1;
    pointer-events: none;
  }

  .photo-thumb-title {
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.1;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }

  .photos-empty {
    min-height: calc(100vh - 160px);
    display: grid;
    place-items: center;
    text-align: center;
    padding: 2rem 1.5rem;
    gap: 0.75rem;
  }

  .photos-empty h1,
  .photos-empty p {
    margin: 0;
  }

  .photos-empty p {
    color: rgba(255, 255, 255, 0.72);
  }

  .photos-stage :global(.blog-pagination) {
    margin: 1.5rem 0 0;
    justify-content: flex-start;
  }

  .photos-stage :global(.blog-pagination-link) {
    color: rgba(255, 255, 255, 0.68);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .photos-stage :global(.blog-pagination-link:hover) {
    background: rgba(255, 255, 255, 0.08);
    color: white;
  }

  .photos-stage :global(.blog-pagination-current) {
    background: white;
    color: #111827;
  }

  .photos-toolbar {
    position: fixed;
    inset-inline: 0;
    bottom: 0;
    z-index: 30;
    min-height: 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1rem 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(24, 24, 24, 0.94);
    backdrop-filter: blur(16px);
  }

  .photos-toolbar-brand {
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .photos-toolbar-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    object-fit: cover;
    flex: 0 0 auto;
  }

  .photos-toolbar-copy {
    min-width: 0;
    font-size: 1rem;
    line-height: 1.25;
    color: rgba(255, 255, 255, 0.9);
  }

  .photos-toolbar-copy strong {
    display: block;
    font-weight: 500;
  }

  .photos-toolbar-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .photos-toolbar-menu {
    position: relative;
  }

  .photos-toolbar-menu > summary,
  .photos-toolbar-icon-button {
    appearance: none;
    border: 0;
    background: transparent;
    color: rgba(255, 255, 255, 0.9);
    cursor: pointer;
    padding: 0.5rem 0.65rem;
    font-size: 1rem;
    line-height: 1;
    border-radius: 999px;
    transition: background-color 180ms ease, color 180ms ease;
    list-style: none;
  }

  .photos-toolbar-menu > summary::-webkit-details-marker {
    display: none;
  }

  .photos-toolbar-menu[open] > summary,
  .photos-toolbar-icon-button:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .photos-toolbar-menu-panel {
    position: absolute;
    right: 0;
    bottom: calc(100% + 0.65rem);
    min-width: 12rem;
    display: grid;
    gap: 0.35rem;
    padding: 0.55rem;
    border-radius: 1rem;
    background: rgba(21, 21, 21, 0.98);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.35);
  }

  .photos-toolbar-menu-item {
    display: flex;
    align-items: center;
    min-height: 2.25rem;
    padding: 0.5rem 0.75rem;
    border-radius: 0.75rem;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.92rem;
  }

  .photos-toolbar-menu-item.is-active {
    color: white;
    background: rgba(255, 255, 255, 0.08);
  }

  .photos-lightbox {
    width: 100vw;
    max-width: none;
    height: 100vh;
    max-height: none;
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    color: white;
    overflow: visible;
  }

  .photos-lightbox[open] {
    display: grid;
    place-items: center;
  }

  .photos-lightbox::backdrop {
    background: rgba(6, 9, 14, 0.72);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
  }

  .photos-lightbox-frame {
    position: relative;
    display: inline-block;
    max-width: calc(100vw - 100px);
    background: rgba(31, 34, 36, 0.925);
    box-shadow: 0 1em 3em 0.5em rgba(0, 0, 0, 0.25);
    border-radius: 12px;
    overflow: hidden;
  }

  .photos-lightbox-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0;
    transition: opacity 0.2s ease-in-out;
    pointer-events: none;
    background-image:
      linear-gradient(to left, rgba(31, 34, 36, 0.35), rgba(31, 34, 36, 0) 10em, rgba(31, 34, 36, 0)),
      linear-gradient(to right, rgba(31, 34, 36, 0.35), rgba(31, 34, 36, 0) 10em, rgba(31, 34, 36, 0));
  }

  .photos-lightbox-frame:hover::before {
    opacity: 1;
  }

  .photos-lightbox-close,
  .photos-lightbox-nav {
    appearance: none;
    border: 0;
    background: transparent;
    color: white;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    z-index: 2;
    transition: opacity 0.2s ease-in-out;
  }

  .photos-lightbox-frame:hover .photos-lightbox-close,
  .photos-lightbox-frame:hover .photos-lightbox-nav {
    opacity: 0.5;
  }

  @media (hover: none), (pointer: coarse) {
    .photos-lightbox-close,
    .photos-lightbox-nav {
      opacity: 1;
    }
  }

  .photos-lightbox-close:hover,
  .photos-lightbox-nav:hover {
    opacity: 1;
  }

  .photos-lightbox-close {
    position: absolute;
    top: 0;
    right: 0;
    width: 5em;
    height: 5em;
  }

  .photos-lightbox-nav {
    position: absolute;
    top: 50%;
    margin-top: -4em;
    width: 6em;
    height: 8em;
  }

  .photos-lightbox-nav-prev {
    left: 0;
  }

  .photos-lightbox-nav-next {
    right: 0;
  }

  .photos-lightbox-nav:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .photos-lightbox-figure {
    margin: 0;
    position: relative;
  }

  .photos-lightbox-image {
    display: block;
    max-width: min(calc(100vw - 100px), 1480px);
    max-height: calc(100vh - 100px);
    object-fit: contain;
    border-radius: 0;
  }

  .photos-lightbox-caption {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.5rem;
    padding: 2rem 2rem 0.1rem;
    min-height: 13rem;
    text-align: left;
    background-image: linear-gradient(to top, rgba(16, 16, 16, 0.45) 25%, rgba(16, 16, 16, 0) 100%);
  }

  .photos-lightbox-title {
    margin: 0;
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .photos-lightbox-description {
    margin: 0;
    color: #ffffff;
    font-size: 15px;
    line-height: 1.5;
  }

  .photos-lightbox-meta,
  .photos-lightbox-tags,
  .photos-lightbox-dots {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem;
  }

  .photos-lightbox-meta-item,
  .photos-lightbox-category,
  .photos-lightbox-taglist {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.86);
  }

  .photos-lightbox-dots {
    gap: 0.5rem;
  }

  .photos-lightbox-dot {
    appearance: none;
    width: 8px;
    height: 8px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: background-color 180ms ease, transform 180ms ease;
  }

  .photos-lightbox-dot.is-active {
    background: #ffffff;
    transform: scale(1.15);
  }

  [data-photos-root]:fullscreen,
  [data-photos-root]:-webkit-full-screen {
    width: 100%;
    height: 100%;
    overflow: auto;
    background: #181818;
  }

  @media (max-width: 1680px) {
    .photos-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
