---
import { siteConfig } from '@/config/site';
import {
  getLocalizedPath,
  type Locale,
} from '@/i18n';
import type { GalleryEntry } from '@/lib/gallery';

interface Props {
  locale: Locale;
  entries: GalleryEntry[];
  categories: string[];
  currentPage: number;
  totalPages: number;
  basePath: string;
  showHeader?: boolean;
  bottomToolbarLabel?: string;
  showBottomAboutLink?: boolean;
  bottomToolbarName?: string;
  bottomToolbarSubtitle?: string;
}

const {
  locale,
  entries,
  categories,
  currentPage,
  totalPages,
  basePath,
  showHeader = true,
  bottomToolbarLabel = '底部操作栏',
  showBottomAboutLink = true,
  bottomToolbarName,
  bottomToolbarSubtitle,
} = Astro.props;

const galleryHref = getLocalizedPath(basePath, locale);
const galleryPageHref = (page: number) =>
  page === 1
    ? galleryHref
    : getLocalizedPath(`${basePath}/page/${page}/`, locale);
const timePlusConfig = siteConfig.timeplusGallery ?? {};
const githubLink = timePlusConfig.githubHref || 'https://github.com/zhheo/TimePlus';
const authorHomeLink = timePlusConfig.homeHref || 'https://zhheo.com/';
const authorSocialLink = timePlusConfig.weiboHref || 'https://weibo.com/u/6277622585';
const indexName = timePlusConfig.indexName || timePlusConfig.brandName || 'TimePlus';
const indexSuffix = timePlusConfig.indexSuffix || timePlusConfig.subtitle || '一款简约的相册主题';
const headerName = timePlusConfig.headerName || indexName;
const headerSubtitle = timePlusConfig.headerSubtitle || indexSuffix;
const toolbarName = bottomToolbarName ?? headerName;
const toolbarSubtitle = bottomToolbarSubtitle ?? headerSubtitle;
const aboutHtml =
  timePlusConfig.aboutHtml ||
  'A minimalist photo album theme by ZHHEO & ZMKI, rebuilt on Astro while preserving the original visual and interaction model.';
const aboutText = aboutHtml.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();

const timePlusUi = {
  indexName,
  pageTitle: `${indexName} - ${indexSuffix}`,
  name: toolbarName,
  title: toolbarSubtitle,
  description: aboutText,
  aboutHtml,
  categoriesLabel: '分类',
  allLabel: '全部',
  fullscreen: '切换全屏',
  exitFullscreen: '退出全屏',
  aboutLinkLabel: '关于',
  aboutTitle: `关于${indexName}`,
  contactTitle: '联系我',
  previousLabel: '上一页',
  nextLabel: '下一页',
  emptyTitle: '暂无内容',
  emptyDescription: '当前还没有相册内容。',
  copyright: '© 设计 ZHHEO & ZMKI',
  themeLabel: '主题',
  themeName:
    timePlusConfig.themeDisplayName ||
    '洪墨时光',
  police: timePlusConfig.police || '',
  icp: timePlusConfig.icp || '',
  statsHtml: timePlusConfig.statsHtml || '',
  logo: timePlusConfig.logo || '/timeplus/info/timeplus.webp',
  ogImage: timePlusConfig.ogImage || '/timeplus/info/timeplus.webp',
  thumbSuffix: timePlusConfig.thumbnailSuffix || '',
  displaySuffix: timePlusConfig.displaySuffix || '',
};

function formatDate(date: Date) {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
}

function getEntryCover(entry: GalleryEntry) {
  return entry.data.cover ?? entry.data.images[0];
}

function getThumbUrl(entry: GalleryEntry) {
  return `${getEntryCover(entry)}${timePlusUi.thumbSuffix}`;
}

function getDisplayUrl(entry: GalleryEntry) {
  return `${getEntryCover(entry)}${timePlusUi.displaySuffix}`;
}

function getPageRange() {
  const maxPages = 6;
  const start = Math.max(1, Math.min(currentPage - Math.floor(maxPages / 2), totalPages - maxPages + 1));
  const end = Math.min(start + maxPages - 1, totalPages);
  return { start, end };
}

const { start: pageStart, end: pageEnd } = getPageRange();
---

{
  showHeader && (
    <header id="header" aria-label={bottomToolbarLabel}>
      <a href={galleryHref}><img class="site-logo" src={timePlusUi.logo} alt={timePlusUi.name} /></a>
      <h1><a href={galleryHref}><strong>{timePlusUi.name}</strong></a></h1>
      <span class="discription">{timePlusUi.title}</span>
      <nav aria-label={bottomToolbarLabel}>
        <ul class="nav_links">
          <li class="nav-item">
            <a class="icon solid fa-info-circle nav-item-name">{timePlusUi.categoriesLabel}</a>
            <ul class="nav-item-child">
              <li class="category-level-0 category-parent">
                <a href={galleryHref} style="cursor: pointer;">{timePlusUi.allLabel}</a>
              </li>
              {
                categories.map((category) => (
                  <li class="category-level-0 category-parent">
                    <a style="cursor: pointer;">{category}</a>
                  </li>
                ))
              }
            </ul>
          </li>
          <li>
            <a
              type="button"
              id="fullscreen"
              class="btn btn-default visible-lg visible-md"
              data-enter-fullscreen-label={timePlusUi.fullscreen}
              data-exit-fullscreen-label={timePlusUi.exitFullscreen}
              aria-label={timePlusUi.fullscreen}
              title={timePlusUi.fullscreen}
            >
              <i class="iconfont icon-quanping"></i>
            </a>
          </li>
          {
            showBottomAboutLink && <li><a href="#footer">{timePlusUi.aboutLinkLabel}</a></li>
          }
        </ul>
      </nav>
    </header>
  )
}

<div id="wrapper" data-timeplus-gallery data-gallery-root class:list={[!showHeader && 'no-local-header']}>
  <div id="main">
    {
      entries.length > 0 ? (
        entries.map((entry) => (
          <article class="thumb img-area" data-gallery-item>
            <a class="image my-photo" href={getDisplayUrl(entry)}>
              <img
                class="zmki_px my-photo"
                src="/timeplus/assets/img/loading.gif"
                data-src={getThumbUrl(entry)}
                alt={entry.data.title}
                onerror="this.src='/timeplus/assets/img/loading.gif';this.onerror=null"
              />
            </a>
            <h2>{entry.data.title}</h2>
            {entry.data.description && (
              <div class="content-wrapper">
                <p>{entry.data.description}</p>
              </div>
            )}
            <li class="tag-info tag-info-bottom">
              {entry.data.device && (
                <span class="tag-device"><i class="iconfont icon-camera-lens-line"></i>{entry.data.device}</span>
              )}
              {entry.data.location && (
                <span class="tag-location"><i class="iconfont icon-map-pin-2-line"></i>{entry.data.location}</span>
              )}
              <span class="tag-time"><i class="iconfont icon-time-line"></i>{formatDate(entry.data.date)}</span>
            </li>
            <li class="tag-info">
              <span class="tag-categorys">{entry.data.category}</span>
              {entry.data.tags?.length ? (
                <span class="tag-list">{entry.data.tags.join(' · ')}</span>
              ) : null}
            </li>
            {entry.data.images.length > 1 && (
              <div class="breadcrumb-nav" data-images={JSON.stringify(entry.data.images)}>
                {
                  entry.data.images.map((_, index) => (
                    <span class:list={['nav-dot', index === 0 && 'active']} data-index={String(index)}></span>
                  ))
                }
              </div>
            )}
          </article>
        ))
      ) : (
        <section class="gallery-empty-state">
          <h2>{timePlusUi.emptyTitle}</h2>
          <p>{timePlusUi.emptyDescription}</p>
        </section>
      )
    }
    {
      totalPages > 1 && (
        <div class="pagination-container">
          {
            currentPage > 1 && (
              <a href={galleryPageHref(currentPage - 1)} class="page-btn prev-btn">
                {timePlusUi.previousLabel}
              </a>
            )
          }
          {
            Array.from({ length: pageEnd - pageStart + 1 }, (_, index) => {
              const page = pageStart + index;
              return page === currentPage ? (
                <span class="page-btn current">{page}</span>
              ) : (
                <a href={galleryPageHref(page)} class="page-btn">{page}</a>
              );
            })
          }
          {
            currentPage < totalPages && (
              <a href={galleryPageHref(currentPage + 1)} class="page-btn next-btn">
                {timePlusUi.nextLabel}
              </a>
            )
          }
        </div>
      )
    }
    <div id="load-more" data-page={String(currentPage)} data-total-pages={String(totalPages)}></div>
  </div>
</div>

<footer id="footer" class="panel">
  <div id="about">
    <section>
      <h2>{timePlusUi.aboutTitle}</h2>
      <p set:html={timePlusUi.aboutHtml} />
    </section>
    <section>
      <h2>{timePlusUi.contactTitle}</h2>
      <ul class="icons">
        <li><a class="contact_link" href={authorHomeLink} target="_blank" rel="noopener nofollow"><i class="iconfont icon-shouye"></i></a></li>
        <li>
          <a
            class="contact_link"
            href={authorSocialLink}
            target="_blank"
            rel="noopener nofollow"
          ><i class="iconfont icon-weibo"></i></a>
        </li>
        <li>
          <a
            class="contact_link"
            href={githubLink}
            target="_blank"
            rel="noopener nofollow"
          ><i class="iconfont icon-github"></i></a>
        </li>
      </ul>
    </section>
    <span style="color: #b5b5b5; font-size: 0.8em;">
      {timePlusUi.statsHtml ? <Fragment set:html={timePlusUi.statsHtml} /> : null}
      <div class="copyright-info">
        <span class="copyright">{timePlusUi.copyright}</span>
        <span class="theme">
          {timePlusUi.themeLabel}：
          <a href={githubLink} target="_blank" rel="noopener nofollow">{timePlusUi.themeName}</a>
        </span>
        {
          timePlusUi.police && (
            <span class="police">
              <img src="/timeplus/assets/img/police.png" alt="公安备案" style="vertical-align: middle; width: 14px;" />
              <a href="https://beian.mps.gov.cn/#/query/webSearch" target="_blank" rel="noopener nofollow">
                {timePlusUi.police}
              </a>
            </span>
          )
        }
        {
          timePlusUi.icp && (
            <span class="icp">
              <a href="http://beian.miit.gov.cn/" target="_blank" rel="noopener nofollow">{timePlusUi.icp}</a>
            </span>
          )
        }
      </div>
    </span>
  </div>
</footer>

<script is:inline src="/timeplus/assets/js/jquery.min.js"></script>
<script is:inline src="/timeplus/assets/js/jquery.poptrox.min.js"></script>
<script is:inline src="/timeplus/assets/js/browser.min.js"></script>
<script is:inline src="/timeplus/assets/js/breakpoints.min.js"></script>
<script is:inline src="/timeplus/assets/js/util.js"></script>
<script is:inline src="/timeplus/assets/js/main.js"></script>
<script is:inline src="/timeplus/gallery.js"></script>
