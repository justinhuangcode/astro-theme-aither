---
import TimePlusLayout from '@/layouts/TimePlusLayout.astro';
import { siteConfig } from '@/config/site';
import type { Locale } from '@/i18n';
import type { GalleryEntry } from '@/lib/gallery';
import TimePlusGalleryScene from './TimePlusGalleryScene.astro';

interface Props {
  locale: Locale;
  entries: GalleryEntry[];
  categories: string[];
  currentPage: number;
  totalPages: number;
}

const { locale, entries, categories, currentPage, totalPages } = Astro.props;
const timePlusConfig = siteConfig.timeplusGallery ?? {};
const indexName = timePlusConfig.indexName || timePlusConfig.brandName || 'TimePlus';
const indexSuffix = timePlusConfig.indexSuffix || timePlusConfig.subtitle || '一款简约的相册主题';
const headerSubtitle = timePlusConfig.headerSubtitle || indexSuffix;
const aboutHtml =
  timePlusConfig.aboutHtml ||
  'A minimalist photo album theme by ZHHEO & ZMKI, rebuilt on Astro while preserving the original visual and interaction model.';
const aboutText = aboutHtml.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
const title = `${indexName} - ${indexSuffix}`;
const description = aboutText || headerSubtitle;
const image = timePlusConfig.ogImage || '/timeplus/info/timeplus.webp';
---

<TimePlusLayout
  locale={locale}
  title={title}
  description={description}
  image={image}
  bodyClass="is-preload timeplus-gallery-page"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/timeplus/iconfont.css" />
    <link rel="stylesheet" href="/timeplus/assets/css/main.css" />
    <link rel="stylesheet" href="/timeplus/gallery-overrides.css" />
    <noscript>
      <link rel="stylesheet" href="/timeplus/assets/css/noscript.css" />
    </noscript>
  </Fragment>

  <TimePlusGalleryScene
    locale={locale}
    entries={entries}
    categories={categories}
    currentPage={currentPage}
    totalPages={totalPages}
    basePath="/gallery2"
    showHeader={true}
  />
</TimePlusLayout>
