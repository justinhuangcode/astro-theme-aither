---
import NavOnlyLayout from '@/layouts/NavOnlyLayout.astro';
import { siteConfig } from '@/config/site';
import { getMessages, type Locale } from '@/i18n';
import type { GalleryEntry } from '@/lib/gallery';
import PhotosGalleryScene from './PhotosGalleryScene.astro';

interface Props {
  locale: Locale;
  entries: GalleryEntry[];
  categories: string[];
  currentPage: number;
  totalPages: number;
}

const { locale, entries, categories, currentPage, totalPages } = Astro.props;
const m = getMessages(locale);
const authorAvatar = siteConfig.author.avatar;
---

<NavOnlyLayout
  locale={locale}
  title={`${m.nav.gallery} | ${siteConfig.name}`}
  description={siteConfig.description}
  mainClass="bg-[#181818]"
  bodyClass="photos-gallery-page"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/photos-ui/iconfont.css" />
    <link rel="stylesheet" href="/photos-ui/assets/css/embedded-main.css" />
    <link rel="stylesheet" href="/photos-ui/embedded-overrides.css" />
    <noscript>
      <link rel="stylesheet" href="/photos-ui/assets/css/embedded-noscript.css" />
    </noscript>
  </Fragment>

  <div data-photos-fullscreen-root>
    <div class="photos-gallery-scope">
      <PhotosGalleryScene
        locale={locale}
        entries={entries}
        categories={categories}
        currentPage={currentPage}
        totalPages={totalPages}
        basePath="/photos"
        showHeader={true}
        bottomToolbarLabel={m.galleryPage.bottomToolbarLabel}
        showBottomAboutLink={false}
        bottomToolbarLogo={authorAvatar}
        bottomToolbarName={m.galleryPage.embeddedToolbarName}
        bottomToolbarSubtitle=""
      />
    </div>
  </div>
</NavOnlyLayout>
