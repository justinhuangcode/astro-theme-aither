---
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config/site';
import { translateNav, type Locale } from '@/i18n';
import DirectoryIcon from '@/components/directory/DirectoryIcon.astro';
import { getDirectoryContent } from '@/lib/directory';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const title = translateNav('directory', locale);
const content = getDirectoryContent(locale);
const description = content.heroSubtitle;
---

<Layout
  title={`${title} | ${siteConfig.name}`}
  description={description}
  enableCrisp={false}
  hideFooter={true}
  hideLocaleBanner={true}
  mainClass="bg-transparent"
>
  <section class="directory-page-shell">
    <div class="directory-page-layout">
      <aside class="directory-sidebar">
        <a class="directory-sidebar-logo" href="#directory-hero" aria-label={content.heroTitle}>
          <img src={content.logoImage} alt={content.heroTitle} loading="eager" decoding="async" />
        </a>

        <nav class="directory-sidebar-nav" aria-label={`${title} sections`}>
          {
            content.groups.map((group) => (
              <a
                href={`#${group.id}`}
                class="directory-sidebar-link"
                data-directory-sidebar-link
                data-target={group.id}
              >
                <DirectoryIcon name={group.icon} class="directory-sidebar-link-icon" />
                <span>{group.title}</span>
              </a>
            ))
          }
        </nav>

        <div class="directory-sidebar-footer">
          <p class="directory-sidebar-footer-title">{content.sidebarFooter}</p>
          <p class="directory-sidebar-footer-meta">{content.sidebarThemeAttribution}</p>
        </div>
      </aside>

      <div class="directory-main">
        <section id="directory-hero" class="directory-hero">
          <img
            class="directory-hero-image"
            src={content.heroImage}
            alt={content.heroTitle}
            loading="eager"
            decoding="async"
          />
          <div class="directory-hero-overlay"></div>
          <div class="directory-hero-copy">
            <h1>{content.heroTitle}</h1>
            <p>{content.heroSubtitle}</p>
          </div>
        </section>

        <nav class="directory-mobile-nav" aria-label={`${title} sections`}>
          {
            content.groups.map((group) => (
              <a
                href={`#${group.id}`}
                class="directory-mobile-chip"
                data-directory-mobile-link
                data-target={group.id}
              >
                <DirectoryIcon name={group.icon} class="directory-mobile-chip-icon" />
                <span>{group.title}</span>
              </a>
            ))
          }
        </nav>

        <div class="directory-groups">
          {
            content.groups.map((group) => (
              <section id={group.id} class="directory-group" data-directory-group-section>
                <header class="directory-group-header">
                  <DirectoryIcon name={group.icon} class="directory-group-header-icon" />
                  <h2>{group.title}</h2>
                </header>

                <div class="directory-card-grid">
                  {
                    group.items.map((item) => (
                      <a
                        href={item.href}
                        class="directory-card"
                        target={item.external ? '_blank' : undefined}
                        rel={item.external ? 'noreferrer noopener' : undefined}
                      >
                        <div class="directory-card-logo-wrap">
                          <img
                            class="directory-card-logo"
                            src={item.logo}
                            alt={item.title}
                            loading="lazy"
                            decoding="async"
                          />
                        </div>
                        <div class="directory-card-copy">
                          <p class="directory-card-title">{item.title}</p>
                          <p class="directory-card-description">{item.description}</p>
                        </div>
                      </a>
                    ))
                  }
                </div>
              </section>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const links = Array.from(
    document.querySelectorAll<HTMLElement>(
      '[data-directory-sidebar-link], [data-directory-mobile-link]'
    )
  );
  const sections = Array.from(
    document.querySelectorAll<HTMLElement>('[data-directory-group-section]')
  );

  if (links.length > 0 && sections.length > 0) {
    const setActiveLink = (id: string) => {
      links.forEach((link) => {
        link.classList.toggle('is-active', link.dataset.target === id);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (visible?.target?.id) setActiveLink(visible.target.id);
      },
      {
        rootMargin: '-120px 0px -55% 0px',
        threshold: [0.15, 0.35, 0.6],
      }
    );

    sections.forEach((section) => observer.observe(section));
    setActiveLink(sections[0].id);
  }
</script>

<style is:global>
  @import url('/directory/remixicon/remixicon.css');
</style>

<style>
  .directory-page-shell {
    background: #f5f6f8;
    min-height: calc(100vh - 58px);
    color: #1d1f24;
  }

  :global(.dark) .directory-page-shell {
    background: #0f1115;
    color: #f2f4f8;
  }

  .directory-page-layout {
    max-width: 1560px;
    margin: 0 auto;
    padding: 16px 16px 30px;
    display: grid;
    grid-template-columns: 250px minmax(0, 1fr);
    gap: 14px;
  }

  .directory-sidebar,
  .directory-main {
    min-width: 0;
  }

  .directory-sidebar {
    position: sticky;
    top: 80px;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.06);
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    border-radius: 18px;
    padding: 14px 12px 16px;
  }

  :global(.dark) .directory-sidebar {
    background: #181a20;
    border-color: rgba(255, 255, 255, 0.05);
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.24);
  }

  .directory-sidebar-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 16px;
    overflow: hidden;
    min-height: 100px;
    background: #edf1f7;
  }

  :global(.dark) .directory-sidebar-logo {
    background: #16181e;
  }

  .directory-sidebar-logo img {
    width: 100%;
    height: auto;
    display: block;
  }

  .directory-sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .directory-sidebar-link {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 8px 12px;
    border-radius: 12px;
    color: inherit;
    font-size: 16px;
    line-height: 1.25;
    text-decoration: none;
    transition: background-color 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .directory-sidebar-link:hover,
  .directory-sidebar-link.is-active {
    background: #edf1f7;
    color: #111827;
    text-decoration: none;
  }

  :global(.dark) .directory-sidebar-link:hover,
  :global(.dark) .directory-sidebar-link.is-active {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
  }

  :global(.directory-sidebar-link-icon) {
    width: 20px;
    height: 20px;
    flex: none;
    opacity: 0.88;
    display: block;
  }

  .directory-sidebar-footer {
    margin-top: auto;
    padding: 8px 8px 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .directory-sidebar-footer-title,
  .directory-sidebar-footer-meta {
    margin: 0;
    font-size: 13px;
    line-height: 1.35;
    color: #6b7280;
  }

  :global(.dark) .directory-sidebar-footer-title,
  :global(.dark) .directory-sidebar-footer-meta {
    color: #9ca3af;
  }

  .directory-main {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .directory-hero {
    position: relative;
    min-height: 280px;
    max-height: 300px;
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    box-shadow: 0 12px 32px rgba(31, 41, 55, 0.12);
  }

  .directory-hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .directory-hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(10, 10, 16, 0.1) 0%, rgba(10, 10, 16, 0.56) 100%),
      linear-gradient(90deg, rgba(15, 23, 42, 0.76) 0%, rgba(15, 23, 42, 0.12) 62%);
  }

  .directory-hero-copy {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 28px 32px 24px;
    color: #fff;
    max-width: 560px;
  }

  .directory-hero-copy h1,
  .directory-hero-copy p {
    margin: 0;
  }

  .directory-hero-copy h1 {
    font-size: clamp(2rem, 2.2vw, 2.8rem);
    line-height: 1.05;
    font-weight: 780;
    letter-spacing: -0.03em;
  }

  .directory-hero-copy p {
    font-size: 1rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.88);
  }

  .directory-mobile-nav {
    display: none;
    gap: 10px;
    overflow-x: auto;
    padding: 2px 0;
    scrollbar-width: none;
  }

  .directory-mobile-nav::-webkit-scrollbar {
    display: none;
  }

  .directory-mobile-chip {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    white-space: nowrap;
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    color: #111827;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
  }

  :global(.dark) .directory-mobile-chip {
    background: rgba(22, 24, 30, 0.95);
    color: #f4f5f7;
  }

  .directory-mobile-chip.is-active {
    background: #111827;
    color: #fff;
  }

  :global(.dark) .directory-mobile-chip.is-active {
    background: #fff;
    color: #111827;
  }

  :global(.directory-mobile-chip-icon) {
    width: 18px;
    height: 18px;
    flex: none;
    display: block;
  }

  .directory-groups {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .directory-group {
    scroll-margin-top: 92px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .directory-group-header {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 18px;
    line-height: 1;
    color: #20242e;
  }

  :global(.dark) .directory-group-header {
    color: #f6f7fb;
  }

  .directory-group-header h2 {
    margin: 0;
    font-size: 17px;
    font-weight: 780;
  }

  :global(.directory-group-header-icon) {
    width: 18px;
    height: 18px;
    flex: none;
    opacity: 0.88;
    display: block;
  }

  .directory-card-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .directory-card {
    display: flex;
    align-items: center;
    gap: 14px;
    min-height: 80px;
    padding: 10px 14px;
    border-radius: 12px;
    background: #ffffff;
    border: 1px solid rgba(17, 24, 39, 0.06);
    color: inherit;
    text-decoration: none;
    box-shadow: 0 6px 18px rgba(15, 23, 42, 0.05);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease;
  }

  .directory-card:hover {
    transform: translateY(-1px);
    background: #ffffff;
    color: inherit;
    border-color: rgba(59, 130, 246, 0.18);
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    text-decoration: none;
  }

  :global(.dark) .directory-card {
    background: #171920;
    border-color: rgba(255, 255, 255, 0.05);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.26);
  }

  :global(.dark) .directory-card:hover {
    background: #1d2028;
    color: inherit;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .directory-card-logo-wrap {
    width: 60px;
    height: 60px;
    border-radius: 18px;
    overflow: hidden;
    flex: none;
    background: #eef2f7;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(.dark) .directory-card-logo-wrap {
    background: #111318;
  }

  .directory-card-logo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .directory-card-copy {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .directory-card-title,
  .directory-card-description {
    margin: 0;
  }

  .directory-card-title {
    font-size: 17px;
    line-height: 1.15;
    font-weight: 760;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .directory-card-description {
    font-size: 14px;
    line-height: 1.15;
    color: #6b7280;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .directory-card:hover .directory-card-description {
    color: rgba(255, 255, 255, 0.78);
  }

  @media (max-width: 1320px) {
    .directory-page-layout {
      grid-template-columns: 228px minmax(0, 1fr);
    }

    .directory-card-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 980px) {
    .directory-page-layout {
      grid-template-columns: 1fr;
      padding-inline: 14px;
    }

    .directory-sidebar {
      display: none;
    }

    .directory-mobile-nav {
      display: flex;
    }

    .directory-card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .directory-page-shell {
      min-height: calc(100vh - 58px);
    }

    .directory-page-layout {
      padding-block: 12px 22px;
    }

    .directory-hero {
      min-height: 220px;
      border-radius: 16px;
    }

    .directory-hero-copy {
      padding: 24px 22px;
    }

    .directory-card-grid {
      grid-template-columns: 1fr;
    }

    .directory-card {
      min-height: 84px;
    }
  }
</style>
