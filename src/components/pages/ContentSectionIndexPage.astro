---
import type { CollectionKey } from 'astro:content';
import BlogCard from '@/components/BlogCard.astro';
import BlogGrid from '@/components/BlogGrid.astro';
import Container from '@/components/Container.astro';
import { siteConfig, type ContentSection } from '@/config/site';
import {
  getLocaleBasePath,
  translateNav,
  type Locale,
} from '@/i18n';
import { getSlug, type LocalizedEntry } from '@/lib/posts';
import Layout from '@/layouts/Layout.astro';

interface Props {
  locale: Locale;
  section: ContentSection;
  entries: Array<LocalizedEntry<CollectionKey>>;
}

const { locale, section, entries } = Astro.props;
const title = translateNav(section.labelKey, locale);
const basePath = getLocaleBasePath(locale);
---

<Layout title={`${title} | ${siteConfig.name}`}>
  <Container class="px-4">
    <div class="mt-8">
      <h1 class="text-2xl font-semibold mb-6 text-[var(--color-link)]">{title}</h1>
      <BlogGrid>
        {
          entries.map((entry) => (
            <BlogCard
              slug={getSlug(entry.id)}
              title={entry.data.title}
              date={entry.data.date}
              basePath={basePath}
              section={section.id}
              pinned={entry.data.pinned}
            />
          ))
        }
      </BlogGrid>
    </div>
  </Container>
</Layout>
