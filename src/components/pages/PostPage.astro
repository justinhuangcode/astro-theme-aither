---
import { render } from 'astro:content';
import ArticlePageBody from '@/components/pages/ArticlePageBody.astro';
import PostSourceContext from '@/components/posts/PostSourceContext.astro';
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config/site';
import { getSlug, type PostEntry } from '@/lib/posts';
import { buildPostTagHref } from '@/lib/post-taxonomy';
import {
  getLocaleHomePath,
  getPostMarkdownPath,
  getPostOgImagePath,
  getPostPath,
  toAbsoluteSiteUrl,
} from '@/lib/site-content';
import { getMessages, type Locale } from '@/i18n';

interface Props {
  locale: Locale;
  post: PostEntry;
  prevPost: PostEntry | null;
  nextPost: PostEntry | null;
}

const { locale, post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);
const m = getMessages(locale);
const slug = getSlug(post.id);
const postPath = getPostPath(locale, slug);
const postUrl = toAbsoluteSiteUrl(postPath);
const homeUrl = toAbsoluteSiteUrl(getLocaleHomePath(locale));
const sourceUrl = post.data.sourceUrl
  ? new URL(post.data.sourceUrl, siteConfig.url).toString()
  : undefined;
const tagHrefs = Object.fromEntries(
  (post.data.tags ?? []).map((tag) => [tag, buildPostTagHref(tag, locale)]),
);
const prevLink = prevPost
  ? { href: getPostPath(locale, getSlug(prevPost.id)), title: prevPost.data.title }
  : null;
const nextLink = nextPost
  ? { href: getPostPath(locale, getSlug(nextPost.id)), title: nextPost.data.title }
  : null;
const articleJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.date.toISOString(),
    author: { '@type': 'Person', name: siteConfig.author.name },
    publisher: { '@type': 'Organization', name: siteConfig.name },
    url: postUrl,
    ...(post.data.sourceTitle ? { alternativeHeadline: post.data.sourceTitle } : {}),
    ...(sourceUrl ? { isBasedOn: sourceUrl } : {}),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: siteConfig.name, item: homeUrl },
      { '@type': 'ListItem', position: 2, name: m.nav.blog, item: homeUrl },
      { '@type': 'ListItem', position: 3, name: post.data.title, item: postUrl },
    ],
  },
];
---

<Layout
  title={`${post.data.title} | ${siteConfig.name}`}
  description={post.data.description}
  image={post.data.image ?? getPostOgImagePath(locale, slug)}
  jsonLd={articleJsonLd}
  enableCrisp={false}
  article={{
    publishedTime: post.data.date.toISOString(),
    author: siteConfig.author.name,
    tags: post.data.tags,
  }}
  alternateFormats={[
    {
      type: 'text/markdown',
      href: getPostMarkdownPath(locale, slug),
      title: `${post.data.title} (Markdown)`,
    },
  ]}
>
  <ArticlePageBody
    locale={locale}
    entry={post}
    content={Content}
    headings={headings}
    prevLink={prevLink}
    nextLink={nextLink}
    tagHrefs={tagHrefs}
  >
    {
      (post.data.sourceTitle || post.data.sourcePublication || sourceUrl) && (
        <PostSourceContext
          slot="above-description"
          locale={locale}
          sourceTitle={post.data.sourceTitle}
          sourcePublication={post.data.sourcePublication}
          sourceUrl={sourceUrl}
        />
      )
    }
  </ArticlePageBody>
</Layout>
