---
import PhotosLayout from '@/layouts/PhotosLayout.astro';
import { siteConfig } from '@/config/site';
import { getMessages, type Locale } from '@/i18n';
import type { GalleryEntry } from '@/lib/gallery';
import PhotosGalleryScene from './PhotosGalleryScene.astro';

interface Props {
  locale: Locale;
  entries: GalleryEntry[];
  categories: string[];
  currentPage: number;
  totalPages: number;
}

const { locale, entries, categories, currentPage, totalPages } = Astro.props;
const m = getMessages(locale);
const photosConfig = siteConfig.photosGallery ?? {};
const indexName = m.galleryPage.name;
const indexSuffix = m.galleryPage.subtitle;
const title = `${indexName} - ${indexSuffix}`;
const description = m.galleryPage.description;
const image = photosConfig.ogImage || '/author-avatar.svg';
---

<PhotosLayout
  locale={locale}
  title={title}
  description={description}
  image={image}
  bodyClass="is-preload photos-gallery-page"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/photos-ui/iconfont.css" />
    <link rel="stylesheet" href="/photos-ui/assets/css/main.css" />
    <link rel="stylesheet" href="/photos-ui/gallery-overrides.css" />
    <noscript>
      <link rel="stylesheet" href="/photos-ui/assets/css/noscript.css" />
    </noscript>
  </Fragment>

  <div data-photos-fullscreen-root>
    <PhotosGalleryScene
      locale={locale}
      entries={entries}
      categories={categories}
      currentPage={currentPage}
      totalPages={totalPages}
      basePath="/gallery2"
      showHeader={true}
    />
  </div>
</PhotosLayout>
