---
import { IconGithub, IconTwitterX, IconDiscord, IconMail, IconRss } from '@/components/icons';
import Container from './Container.astro';
import BuiltWithButton from './BuiltWithButton.astro';
import { siteConfig } from '@/config/site';
import { getMessages, getLocalizedPath, type Locale } from '@/i18n';

const socialIcons: Record<string, any> = {
  github: IconGithub,
  x: IconTwitterX,
  discord: IconDiscord,
  mail: IconMail,
  rss: IconRss,
};

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const m = getMessages(locale);
const currentPath = Astro.url.pathname;
const localePrefix = locale === 'en' ? '' : `/${locale}`;

function isActive(href: string): boolean {
  if (href.includes('#')) return false;
  return currentPath === href;
}

const footerSectionTitles = [m.footer.navigate, m.footer.subscribe, m.footer.source];
---

<footer class="border-t font-body">
  <Container class="px-4">
    <div class="grid grid-cols-2 gap-6 py-6 md:grid-cols-6">
      <div class="col-span-full flex flex-col items-start md:col-span-2">
        <div class="flex items-center gap-2">
          <span aria-hidden="true">✍️</span>
          <span class="text-[18px] font-semibold">{siteConfig.name}</span>
        </div>
        <p class="font-body text-muted-foreground text-base py-2 md:pr-12">
          {m.footer.tagline}
        </p>
        <nav class="flex items-center gap-4 pt-3">
          {
            siteConfig.social.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noreferrer"
                aria-label={link.title}
                class="inline-flex size-11 items-center justify-center rounded-full border border-border hover:bg-primary/10 hover:text-primary hover:border-primary/30 transition-all duration-200"
              >
                {socialIcons[link.icon] && (() => { const Icon = socialIcons[link.icon]; return <Icon className="size-4 [&_path]:fill-current" />; })()}
              </a>
            ))
          }
        </nav>
      </div>

      {
        siteConfig.footer.sections.map((section, i) => (
          <div class:list={["col-span-1 md:col-span-1 flex flex-col items-start", i === 0 && "md:col-start-4"]}>
            <span class="text-sm font-semibold uppercase">{footerSectionTitles[i]}</span>
            <ul class="mt-2 list-inside space-y-2">
              {section.items.map((item) => (
                <li>
                  <a
                    href={item.external ? item.href : getLocalizedPath(item.href, locale)}
                    target={item.external ? '_blank' : undefined}
                    rel={item.external ? 'noopener noreferrer' : undefined}
                    class:list={[
                      "text-sm transition-colors duration-150 hover:text-[var(--color-link)] focus-visible:text-[var(--color-link)]",
                      isActive(item.href)
                        ? "font-semibold text-primary"
                        : "text-muted-foreground",
                    ]}
                  >
                    {item.labelKey ? (m.nav[item.labelKey] ?? item.title) : item.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </Container>

  <div class="py-12">
    <Container
      class="px-4 flex flex-col items-center justify-between gap-4 text-center sm:flex-row sm:text-left"
    >
      <span class="text-muted-foreground text-sm">
        &copy; {siteConfig.footer.copyrightYear === 'auto' ? new Date().getFullYear() : siteConfig.footer.copyrightYear}
        {siteConfig.name}. {m.footer.rightsReserved}
      </span>
      <nav class="flex items-center gap-3 font-mono text-xs text-muted-foreground">
        <a href="/skill.md" class="hover:text-[var(--color-link)] transition-colors py-2 px-1">skill.md</a>
        <a href={`${localePrefix}/llms.txt`} class="hover:text-[var(--color-link)] transition-colors py-2 px-1">llms.txt</a>
        <a href={`${localePrefix}/llms-full.txt`} class="hover:text-[var(--color-link)] transition-colors py-2 px-1">llms-full.txt</a>
      </nav>
      <BuiltWithButton locale={locale} />
    </Container>
  </div>
</footer>
