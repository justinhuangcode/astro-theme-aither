---
import { IconMonitor, IconMoon, IconPalette, IconSun } from '@/components/icons';
import {
  defaultThemeLabels,
  themeGroups,
  type ThemeGroupKey,
  type ThemeLabels,
} from '@/config/themes';
import type { ColorMode, ThemeStyle } from '@/lib/theme';

interface ModeSwitcherLabels {
  light: string;
  dark: string;
  system: string;
  moreThemes: string;
  beta?: string;
  classic: string;
  modern: string;
  extra: string;
  scifi: string;
  toggle: string;
  mainModes?: string;
  colorModeHint?: string;
  themeStyleHint?: string;
  defaultStyle?: string;
}

interface Props {
  labels?: ModeSwitcherLabels;
  themeLabels?: ThemeLabels;
  defaultMode?: ColorMode;
  defaultStyle?: ThemeStyle;
  showMoreThemes?: boolean;
}

const {
  labels = {
    light: 'Light',
    dark: 'Dark',
    system: 'System',
    moreThemes: 'More Themes',
    beta: 'Beta',
    classic: 'Classic',
    modern: 'Modern',
    extra: 'Extra',
    scifi: 'Sci-Fi',
    toggle: 'Appearance settings',
    mainModes: 'Color Mode',
    colorModeHint: 'Choose light, dark, or follow your system.',
    themeStyleHint: 'Pick a visual style. It works with the color mode above.',
    defaultStyle: 'Default Style',
  },
  themeLabels = defaultThemeLabels,
  defaultMode = 'system',
  defaultStyle = 'default',
  showMoreThemes = true,
} = Astro.props;

const baseModes: { key: ColorMode; label: string; icon: typeof IconSun }[] = [
  { key: 'light', label: labels.light, icon: IconSun },
  { key: 'dark', label: labels.dark, icon: IconMoon },
  { key: 'system', label: labels.system, icon: IconMonitor },
];
---

<div
  class="flex items-center gap-1"
  data-mode-switcher
  data-default-mode={defaultMode}
  data-default-style={defaultStyle}
>
  <div class="relative">
    <button
      type="button"
      class="nav-utility-button inline-flex size-[34px] items-center justify-center rounded text-[var(--color-nav-text)] transition-colors hover:text-[var(--color-nav-text-hover)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/50"
      data-color-trigger
      aria-label={labels.mainModes ?? 'Color Mode'}
      aria-haspopup="menu"
      aria-expanded="false"
      aria-controls="desktop-color-menu"
    >
      <span class="relative inline-flex size-[18px] items-center justify-center">
        <span
          class="transition-transform duration-500 ease-in-out"
          data-trigger-icon="sun"
        >
          <IconSun className="size-[18px]" />
        </span>
        <span
          class="absolute transition-transform duration-500 ease-in-out"
          data-trigger-icon="moon"
        >
          <IconMoon className="size-[18px]" />
        </span>
      </span>
    </button>

    <div
      id="desktop-color-menu"
      class="nav-panel absolute right-0 top-[calc(100%+0.55rem)] z-50 hidden w-[15rem] max-w-[calc(100vw-2rem)] overflow-hidden rounded-xl border border-border/70 bg-popover p-1 text-popover-foreground shadow-lg ring-1 ring-foreground/10"
      data-color-panel
      role="menu"
      aria-label={labels.mainModes ?? 'Color Mode'}
    >
      <p class="px-3 pb-1 pt-2 text-[11px] font-medium tracking-[0.02em] text-muted-foreground">
        {labels.mainModes ?? 'Color Mode'}
      </p>
      {
        baseModes.map(({ key, label, icon: Icon }) => (
          <button
            type="button"
            class="nav-panel-link group flex w-full items-center gap-2 rounded-lg px-4 py-3 text-left text-[15px] text-foreground transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:bg-accent focus-visible:text-accent-foreground focus-visible:outline-none data-[active=true]:bg-accent data-[active=true]:font-semibold data-[active=true]:text-primary"
            data-mode-item={key}
            data-active="false"
            role="menuitemradio"
          >
            <Icon className="size-4 shrink-0" />
            <span class="group-hover:font-semibold group-focus:font-semibold">{label}</span>
          </button>
        ))
      }
    </div>
  </div>

  {showMoreThemes && (
    <div class="relative">
      <button
        type="button"
        class="nav-utility-button inline-flex h-[34px] items-center justify-center rounded px-2 text-[var(--color-nav-text)] transition-colors hover:text-[var(--color-nav-text-hover)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/50 data-[active=true]:text-primary"
        data-style-trigger
        data-active="false"
        aria-label={labels.moreThemes}
        aria-haspopup="menu"
        aria-expanded="false"
        aria-controls="desktop-style-menu"
      >
        <IconPalette className="size-[18px]" />
      </button>

      <div
        id="desktop-style-menu"
        class="nav-panel absolute right-0 top-[calc(100%+0.55rem)] z-50 hidden w-[19rem] max-w-[calc(100vw-2rem)] max-h-[70vh] overflow-y-auto rounded-xl border border-border/70 bg-popover p-1 text-popover-foreground shadow-lg ring-1 ring-foreground/10"
        data-style-panel
        role="menu"
        aria-label={labels.moreThemes}
      >
        <div class="flex items-center gap-2 px-3 pb-1 pt-2 text-[11px] font-medium tracking-[0.02em] text-muted-foreground">
          <span>{labels.moreThemes}</span>
          <span class="inline-flex items-center rounded-full border border-primary/20 bg-primary/10 px-1.5 py-0.5 text-[9px] font-semibold uppercase tracking-[0.12em] text-primary/85">
            {labels.beta ?? 'Beta'}
          </span>
        </div>
        {
          labels.themeStyleHint && (
            <p class="px-3 pb-2 text-sm leading-5 text-muted-foreground">
              {labels.themeStyleHint}
            </p>
          )
        }
        <div class="space-y-0.5 pb-1">
          <button
            type="button"
            class="nav-panel-link group flex w-full items-center gap-2 rounded-lg px-4 py-3 text-left text-[15px] text-foreground transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:bg-accent focus-visible:text-accent-foreground focus-visible:outline-none data-[active=true]:bg-accent data-[active=true]:font-semibold data-[active=true]:text-primary"
            data-style-item="default"
            data-active="false"
            role="menuitemradio"
          >
            <span class="inline-block size-3 shrink-0 rounded-full border border-border bg-background" />
            <span class="group-hover:font-semibold group-focus:font-semibold">
              {labels.defaultStyle ?? 'Default Style'}
            </span>
          </button>
        </div>
        {
          themeGroups.map((group) => (
            <section class="py-1">
              <p class="px-3 pb-1 pt-1 text-[11px] font-medium tracking-[0.02em] text-muted-foreground">
                {labels[group.key as ThemeGroupKey]}
              </p>
              <div class="space-y-0.5">
                {group.themes.map((theme) => (
                  <button
                    type="button"
                    class="nav-panel-link group flex w-full items-center gap-2 rounded-lg px-4 py-3 text-left text-[15px] text-foreground transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:bg-accent focus-visible:text-accent-foreground focus-visible:outline-none data-[active=true]:bg-accent data-[active=true]:font-semibold data-[active=true]:text-primary"
                    data-style-item={theme.key}
                    data-active="false"
                    role="menuitemradio"
                  >
                    <span
                      class="inline-block size-3 shrink-0 rounded-full ring-1 ring-foreground/20"
                      style={`background-color:${theme.color}`}
                    />
                    <span class="group-hover:font-semibold group-focus:font-semibold">
                      {themeLabels[theme.key]}
                    </span>
                  </button>
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </div>
  )}
</div>

<style>
  [data-mode-switcher][data-resolved-mode='light'] [data-trigger-icon='sun'] {
    transform: rotate(0deg) scale(1);
  }

  [data-mode-switcher][data-resolved-mode='light'] [data-trigger-icon='moon'] {
    transform: rotate(45deg) scale(0);
  }

  [data-mode-switcher][data-resolved-mode='dark'] [data-trigger-icon='sun'] {
    transform: rotate(-45deg) scale(0);
  }

  [data-mode-switcher][data-resolved-mode='dark'] [data-trigger-icon='moon'] {
    transform: rotate(0deg) scale(1);
  }

</style>

<script>
  import { bootstrapRootInit } from '@/lib/dom-init';
  import {
    THEME_CHANGE_EVENT,
    getStoredThemePreferences,
    isColorMode,
    isThemeStyle,
    resolveColorMode,
    setThemePreferences,
    type ColorMode,
    type ThemeStyle,
  } from '@/lib/theme';

  const DESKTOP_MENU_EVENT = 'aither:desktop-menu-open';

  function runThemeTransition(trigger: HTMLButtonElement | null, update: () => void) {
    if (!document.startViewTransition || !trigger) {
      update();
      return;
    }

    const rect = trigger.getBoundingClientRect();
    const x = rect.left + rect.width / 2;
    const y = rect.top + rect.height / 2;
    const right = window.innerWidth - rect.left;
    const bottom = window.innerHeight - rect.top;
    const maxRadius = Math.hypot(
      Math.max(rect.left, right),
      Math.max(rect.top, bottom),
    );

    const transition = document.startViewTransition(update);
    transition.ready.then(() => {
      document.documentElement.animate(
        {
          clipPath: [
            `circle(0px at ${x}px ${y}px)`,
            `circle(${maxRadius}px at ${x}px ${y}px)`,
          ],
        },
        {
          duration: 700,
          easing: 'ease-in-out',
          pseudoElement: '::view-transition-new(root)',
        },
      );
    });
  }

  bootstrapRootInit('mode-switcher', '[data-mode-switcher]', (root, signal) => {
    const rawDefaultMode = root.dataset.defaultMode ?? '';
    const rawDefaultStyle = root.dataset.defaultStyle ?? '';
    const defaultMode: ColorMode = isColorMode(rawDefaultMode)
      ? rawDefaultMode
      : 'system';
    const defaultStyle: ThemeStyle = isThemeStyle(rawDefaultStyle)
      ? rawDefaultStyle
      : 'default';
    const colorTrigger = root.querySelector('[data-color-trigger]');
    const colorPanel = root.querySelector('[data-color-panel]');
    const styleTrigger = root.querySelector('[data-style-trigger]');
    const stylePanel = root.querySelector('[data-style-panel]');
    const modeItems = Array.from(root.querySelectorAll('[data-mode-item]'));
    const styleItems = Array.from(root.querySelectorAll('[data-style-item]'));

    if (!(colorTrigger instanceof HTMLButtonElement) || !(colorPanel instanceof HTMLElement)) return;

    const closeColorMenu = () => {
      colorPanel.classList.add('hidden');
      colorTrigger.setAttribute('aria-expanded', 'false');
    };

    const closeStyleMenu = () => {
      if (!(styleTrigger instanceof HTMLButtonElement) || !(stylePanel instanceof HTMLElement)) return;
      stylePanel.classList.add('hidden');
      styleTrigger.setAttribute('aria-expanded', 'false');
    };

    const closeMenus = () => {
      closeColorMenu();
      closeStyleMenu();
    };

    const openColorMenu = () => {
      window.dispatchEvent(
        new CustomEvent(DESKTOP_MENU_EVENT, {
          detail: { owner: 'theme' },
        }),
      );
      closeStyleMenu();
      colorPanel.classList.remove('hidden');
      colorTrigger.setAttribute('aria-expanded', 'true');
    };

    const openStyleMenu = () => {
      if (!(styleTrigger instanceof HTMLButtonElement) || !(stylePanel instanceof HTMLElement)) return;
      window.dispatchEvent(
        new CustomEvent(DESKTOP_MENU_EVENT, {
          detail: { owner: 'theme' },
        }),
      );
      closeColorMenu();
      stylePanel.classList.remove('hidden');
      styleTrigger.setAttribute('aria-expanded', 'true');
    };

    const toggleColorMenu = () => {
      if (colorPanel.classList.contains('hidden')) {
        openColorMenu();
      } else {
        closeColorMenu();
      }
    };

    const toggleStyleMenu = () => {
      if (!(styleTrigger instanceof HTMLButtonElement) || !(stylePanel instanceof HTMLElement)) return;
      if (stylePanel.classList.contains('hidden')) {
        openStyleMenu();
      } else {
        closeStyleMenu();
      }
    };

    const sync = () => {
      const { mode, style } = getStoredThemePreferences(defaultMode, defaultStyle);
      const resolvedMode = resolveColorMode(mode);

      modeItems.forEach((item) => {
        if (!(item instanceof HTMLElement)) return;
        const isActive = item.dataset.modeItem === mode;
        item.dataset.active = String(isActive);
        item.setAttribute('aria-checked', String(isActive));
      });

      styleItems.forEach((item) => {
        if (!(item instanceof HTMLElement)) return;
        const isActive = item.dataset.styleItem === style;
        item.dataset.active = String(isActive);
        item.setAttribute('aria-checked', String(isActive));
      });

      if (styleTrigger instanceof HTMLElement) {
        styleTrigger.dataset.active = String(style !== 'default');
      }

      root.dataset.resolvedMode = resolvedMode;
    };

    colorTrigger.addEventListener('click', (event) => {
      event.stopPropagation();
      toggleColorMenu();
    }, { signal });

    modeItems.forEach((item) => {
      if (!(item instanceof HTMLButtonElement)) return;
      item.addEventListener('click', () => {
        const nextMode = item.dataset.modeItem;
        if (!nextMode || !isColorMode(nextMode)) return;
        runThemeTransition(colorTrigger, () => {
          const { style } = getStoredThemePreferences(defaultMode, defaultStyle);
          setThemePreferences({ mode: nextMode, style });
        });
        closeMenus();
      }, { signal });
    });

    if (styleTrigger instanceof HTMLButtonElement) {
      styleTrigger.addEventListener('click', (event) => {
        event.stopPropagation();
        toggleStyleMenu();
      }, { signal });
    }

    styleItems.forEach((item) => {
      if (!(item instanceof HTMLButtonElement)) return;
      item.addEventListener('click', () => {
        const nextStyle = item.dataset.styleItem;
        if (!nextStyle || !isThemeStyle(nextStyle)) return;
        runThemeTransition(styleTrigger instanceof HTMLButtonElement ? styleTrigger : colorTrigger, () => {
          const { mode } = getStoredThemePreferences(defaultMode, defaultStyle);
          setThemePreferences({ mode, style: nextStyle });
        });
        closeMenus();
      }, { signal });
    });

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Node) || !root.contains(event.target)) {
        closeMenus();
      }
    }, { signal });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeMenus();
      }
    }, { signal });

    window.addEventListener(DESKTOP_MENU_EVENT, (event) => {
      const customEvent = event as CustomEvent<{ owner?: string }>;
      if (customEvent.detail?.owner !== 'theme') {
        closeMenus();
      }
    }, { signal });

    window.addEventListener(THEME_CHANGE_EVENT, sync, { signal });
    sync();
  });
</script>
