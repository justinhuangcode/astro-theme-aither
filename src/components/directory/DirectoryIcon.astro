---
import type { DirectoryIconName } from '@/lib/directory';

interface Props {
  name: DirectoryIconName;
  class?: string;
}

const { name, class: className = '' } = Astro.props;

const iconClassMap: Record<DirectoryIconName, string> = {
  services: 'ri-magic-fill',
  'design-sites': 'ri-paint-brush-fill',
  operations: 'ri-mac-fill',
  assets: 'ri-landscape-fill',
  'ai-tools': 'ri-robot-fill',
};
---

<i class:list={['ri', iconClassMap[name], className]} aria-hidden="true"></i>
