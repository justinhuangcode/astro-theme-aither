---
/**
 * Theme visual effects — animated CSS background effects for sci-fi themes.
 * Pure CSS, zero JS, no performance impact on static content.
 */
---

<div class="theme-effects-layer" aria-hidden="true">
  <div class="theme-effects-inner"></div>
</div>

<style is:global>
  .theme-effects-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .theme-effects-inner {
    position: absolute;
    inset: 0;
  }

  /* ── Matrix: animated falling rain ── */
  html.matrix .theme-effects-layer {
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 255, 65, 0.03) 2px,
        rgba(0, 255, 65, 0.03) 4px
      );
  }
  html.matrix .theme-effects-inner {
    background:
      linear-gradient(180deg, rgba(0, 255, 65, 0.06) 0%, transparent 40%);
    animation: matrix-rain 8s linear infinite;
  }
  @keyframes matrix-rain {
    0% { transform: translateY(-100%); opacity: 0.6; }
    50% { opacity: 1; }
    100% { transform: translateY(100%); opacity: 0.6; }
  }

  /* ── Cyberpunk: animated neon pulse ── */
  html.cyberpunk .theme-effects-inner {
    background:
      radial-gradient(ellipse at 20% 80%, rgba(5, 217, 232, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(255, 42, 109, 0.08) 0%, transparent 50%);
    animation: cyberpunk-pulse 6s ease-in-out infinite alternate;
  }
  @keyframes cyberpunk-pulse {
    0% { opacity: 0.5; filter: hue-rotate(0deg); }
    50% { opacity: 1; }
    100% { opacity: 0.5; filter: hue-rotate(15deg); }
  }

  /* ── Black Mirror: animated scanlines + flicker ── */
  html.blackmirror .theme-effects-layer {
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 3px,
        rgba(255, 255, 255, 0.02) 3px,
        rgba(255, 255, 255, 0.02) 4px
      );
  }
  html.blackmirror .theme-effects-inner {
    background: rgba(79, 195, 247, 0.02);
    animation: mirror-flicker 4s steps(3) infinite;
  }
  @keyframes mirror-flicker {
    0%, 90% { opacity: 1; }
    91% { opacity: 0.6; }
    92% { opacity: 1; }
    93% { opacity: 0.7; }
    94%, 100% { opacity: 1; }
  }

  /* ── Evolution: animated network pulse ── */
  html.evolution .theme-effects-layer {
    background-image:
      linear-gradient(rgba(102, 187, 106, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(102, 187, 106, 0.05) 1px, transparent 1px);
    background-size: 40px 40px;
  }
  html.evolution .theme-effects-inner {
    background: radial-gradient(ellipse at 50% 50%, rgba(102, 187, 106, 0.08) 0%, transparent 70%);
    animation: evo-pulse 5s ease-in-out infinite alternate;
  }
  @keyframes evo-pulse {
    0% { transform: scale(0.8); opacity: 0.3; }
    100% { transform: scale(1.2); opacity: 0.8; }
  }

  /* ── Protoss: golden energy shield ── */
  html.protoss .theme-effects-inner {
    background:
      radial-gradient(ellipse at 50% 20%, rgba(255, 215, 0, 0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 80%, rgba(77, 171, 247, 0.1) 0%, transparent 60%);
    animation: protoss-shield 4s ease-in-out infinite alternate;
  }
  @keyframes protoss-shield {
    0% { opacity: 0.5; }
    50% { opacity: 1; }
    100% { opacity: 0.5; }
  }
  html.protoss .theme-effects-layer {
    border-top: 1px solid rgba(255, 215, 0, 0.1);
  }

  /* ── Zerg: organic creep spread ── */
  html.zerg .theme-effects-inner {
    background:
      radial-gradient(ellipse at 30% 90%, rgba(156, 39, 176, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 10%, rgba(124, 179, 66, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 50%, rgba(156, 39, 176, 0.04) 0%, transparent 70%);
    animation: zerg-creep 10s ease-in-out infinite alternate;
  }
  @keyframes zerg-creep {
    0% { transform: scale(1); filter: hue-rotate(0deg); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); filter: hue-rotate(10deg); }
  }

  /* ── Terran: military HUD scanline ── */
  html.terran .theme-effects-layer {
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 4px,
        rgba(255, 143, 0, 0.015) 4px,
        rgba(255, 143, 0, 0.015) 5px
      );
  }
  html.terran .theme-effects-inner {
    background: linear-gradient(180deg, transparent 0%, rgba(255, 143, 0, 0.03) 50%, transparent 100%);
    background-size: 100% 200%;
    animation: terran-scan 6s linear infinite;
  }
  @keyframes terran-scan {
    0% { background-position: 0% 0%; }
    100% { background-position: 0% 200%; }
  }

  /* ── Mechanicus: rotating cog pattern ── */
  html.mechanicus .theme-effects-layer {
    background-image:
      radial-gradient(circle, rgba(183, 28, 28, 0.05) 1px, transparent 1px);
    background-size: 24px 24px;
  }
  html.mechanicus .theme-effects-inner {
    background:
      radial-gradient(ellipse at 50% 50%, rgba(183, 28, 28, 0.06) 0%, transparent 60%);
    animation: mech-rotate 20s linear infinite;
  }
  @keyframes mech-rotate {
    0% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(180deg) scale(1.1); }
    100% { transform: rotate(360deg) scale(1); }
  }

  /* ── Three-Body: twinkling stars ── */
  html.threebody .theme-effects-layer {
    background:
      radial-gradient(1px 1px at 10% 20%, rgba(255, 255, 255, 0.5), transparent),
      radial-gradient(1px 1px at 30% 60%, rgba(255, 255, 255, 0.3), transparent),
      radial-gradient(1px 1px at 50% 10%, rgba(255, 255, 255, 0.6), transparent),
      radial-gradient(1px 1px at 70% 40%, rgba(255, 255, 255, 0.2), transparent),
      radial-gradient(1px 1px at 90% 80%, rgba(255, 255, 255, 0.5), transparent),
      radial-gradient(1px 1px at 15% 85%, rgba(255, 255, 255, 0.3), transparent),
      radial-gradient(1px 1px at 45% 75%, rgba(255, 255, 255, 0.2), transparent),
      radial-gradient(1px 1px at 85% 15%, rgba(255, 255, 255, 0.4), transparent),
      radial-gradient(2px 2px at 25% 45%, rgba(30, 136, 229, 0.6), transparent),
      radial-gradient(2px 2px at 65% 55%, rgba(30, 136, 229, 0.5), transparent),
      radial-gradient(1px 1px at 5% 50%, rgba(255, 255, 255, 0.3), transparent),
      radial-gradient(1px 1px at 55% 30%, rgba(255, 255, 255, 0.4), transparent),
      radial-gradient(1.5px 1.5px at 75% 65%, rgba(30, 136, 229, 0.4), transparent),
      radial-gradient(1px 1px at 35% 15%, rgba(255, 255, 255, 0.5), transparent),
      radial-gradient(1px 1px at 95% 45%, rgba(255, 255, 255, 0.3), transparent);
  }
  html.threebody .theme-effects-inner {
    animation: stars-twinkle 6s ease-in-out infinite alternate;
  }
  @keyframes stars-twinkle {
    0% { opacity: 0.6; }
    25% { opacity: 1; }
    50% { opacity: 0.7; }
    75% { opacity: 0.9; }
    100% { opacity: 0.6; }
  }

  /* ── Zima Blue: breathing gradient ── */
  html.zimablue .theme-effects-inner {
    background:
      linear-gradient(180deg,
        rgba(41, 121, 255, 0.12) 0%,
        transparent 25%,
        transparent 75%,
        rgba(41, 121, 255, 0.08) 100%
      );
    animation: zima-breathe 8s ease-in-out infinite alternate;
  }
  @keyframes zima-breathe {
    0% { opacity: 0.4; transform: scaleY(0.98); }
    100% { opacity: 1; transform: scaleY(1.02); }
  }

  /* ── Westworld: wireframe grid with slow drift ── */
  html.westworld .theme-effects-layer {
    background-image:
      linear-gradient(rgba(212, 167, 106, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212, 167, 106, 0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    animation: westworld-drift 30s linear infinite;
  }
  @keyframes westworld-drift {
    0% { background-position: 0 0; }
    100% { background-position: 60px 60px; }
  }
  html.westworld .theme-effects-inner {
    background: radial-gradient(ellipse at 50% 50%, rgba(212, 167, 106, 0.04) 0%, transparent 70%);
  }

  /* ── POI: surveillance vignette + tracking box ── */
  html.poi .theme-effects-layer {
    background:
      radial-gradient(ellipse at center, transparent 40%, rgba(0, 0, 0, 0.4) 100%);
  }
  html.poi .theme-effects-inner {
    border: 1px solid transparent;
    animation: poi-scan 8s linear infinite;
  }
  html.poi .theme-effects-inner::before {
    content: '';
    position: absolute;
    top: 20%;
    left: 50%;
    width: 60%;
    height: 60%;
    transform: translateX(-50%);
    border: 1px solid rgba(244, 67, 54, 0.08);
    border-radius: 2px;
    animation: poi-target 4s ease-in-out infinite alternate;
  }
  @keyframes poi-scan {
    0% { box-shadow: inset 0 -2px 0 rgba(244, 67, 54, 0.05); }
    50% { box-shadow: inset 0 2px 0 rgba(244, 67, 54, 0.05); }
    100% { box-shadow: inset 0 -2px 0 rgba(244, 67, 54, 0.05); }
  }
  @keyframes poi-target {
    0% { opacity: 0.3; transform: translateX(-50%) scale(0.98); }
    100% { opacity: 0.6; transform: translateX(-50%) scale(1.02); }
  }

  /* ── Glow effects on headings ── */
  html.matrix .prose-content.prose h2,
  html.matrix .prose-content.prose h3 {
    text-shadow: 0 0 15px rgba(0, 255, 65, 0.4);
  }
  html.cyberpunk .prose-content.prose h2 {
    text-shadow: 0 0 20px rgba(5, 217, 232, 0.4);
  }
  html.protoss .prose-content.prose h1,
  html.protoss .prose-content.prose h2 {
    text-shadow: 0 0 20px rgba(255, 215, 0, 0.3);
  }
  html.zimablue .prose-content.prose h2 {
    text-shadow: 0 0 25px rgba(41, 121, 255, 0.4);
  }
  html.threebody .prose-content.prose h2 {
    text-shadow: 0 0 20px rgba(30, 136, 229, 0.3);
  }
  html.zerg .prose-content.prose h1 {
    text-shadow: 0 0 15px rgba(156, 39, 176, 0.4);
  }
  html.mechanicus .prose-content.prose h1 {
    text-shadow: 0 0 15px rgba(183, 28, 28, 0.3);
  }
  html.poi .prose-content.prose h2 {
    text-shadow: 0 0 10px rgba(244, 67, 54, 0.3);
  }

  /* ── Link hover glow ── */
  html.matrix .prose-content.prose a:hover {
    text-shadow: 0 0 8px rgba(0, 255, 65, 0.5);
  }
  html.cyberpunk .prose-content.prose a:hover {
    text-shadow: 0 0 8px rgba(5, 217, 232, 0.5);
  }
  html.protoss .prose-content.prose a:hover {
    text-shadow: 0 0 8px rgba(77, 171, 247, 0.5);
  }
  html.threebody .prose-content.prose a:hover {
    text-shadow: 0 0 8px rgba(30, 136, 229, 0.5);
  }

  /* ── Navbar glow for sci-fi themes ── */
  html.matrix .site-nav { border-color: rgba(0, 255, 65, 0.15); }
  html.cyberpunk .site-nav { border-color: rgba(5, 217, 232, 0.15); }
  html.protoss .site-nav { border-color: rgba(255, 215, 0, 0.15); }
  html.zerg .site-nav { border-color: rgba(156, 39, 176, 0.15); }
  html.threebody .site-nav { border-color: rgba(30, 136, 229, 0.15); }
  html.zimablue .site-nav { border-color: rgba(41, 121, 255, 0.15); }
  html.mechanicus .site-nav { border-color: rgba(183, 28, 28, 0.15); }
  html.poi .site-nav { border-color: rgba(244, 67, 54, 0.1); }
</style>
