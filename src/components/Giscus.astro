---
/**
 * Giscus comment system — auto theme switching, i18n support.
 * Always shows the comment section; loads Giscus when configured,
 * otherwise shows a placeholder.
 */
import { siteConfig } from '@/config/site';
import {
  defaultLocale,
  getMessages,
  giscusLocales,
  type Locale,
} from '@/i18n';
import { IconMessage } from '@/components/icons';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const g = siteConfig.giscus;
const m = getMessages(locale);
const lang = giscusLocales[locale];
const enabled = g.repo !== '' && g.repoId !== '' && g.categoryId !== '';
---

<div class="giscus-wrapper mt-10" data-giscus>
  <p class="text-sm font-semibold mb-4 text-foreground">{m.blog.comments}</p>

  {enabled ? (
    <script
      is:inline
      src="https://giscus.app/client.js"
      data-repo={g.repo}
      data-repo-id={g.repoId}
      data-category={g.category}
      data-category-id={g.categoryId}
      data-mapping={g.mapping}
      data-strict="0"
      data-reactions-enabled={g.reactionsEnabled ? '1' : '0'}
      data-emit-metadata={g.emitMetadata ? '1' : '0'}
      data-input-position={g.inputPosition}
      data-theme="preferred_color_scheme"
      data-lang={lang}
      data-loading="lazy"
      crossorigin="anonymous"
      async
    />
  ) : (
    <div class="rounded border border-dashed border-border py-8 flex flex-col items-center gap-2 text-muted-foreground text-sm">
      <IconMessage className="size-5" />
      <span>{m.blog.commentsPlaceholder}</span>
    </div>
  )}
</div>

<script>
  import { bootstrapRootInit } from '@/lib/dom-init';

  bootstrapRootInit('giscus', '[data-giscus]', (root, signal) => {
    const updateGiscusTheme = () => {
      const isDark = document.documentElement.classList.contains('dark');
      const theme = isDark ? 'dark' : 'light';
      const iframe = root.querySelector<HTMLIFrameElement>('iframe.giscus-frame');
      if (iframe) {
        iframe.contentWindow?.postMessage(
          { giscus: { setConfig: { theme } } },
          'https://giscus.app'
        );
      }
    };

    const observer = new MutationObserver((mutations) => {
      for (const mutation of mutations) {
        if (mutation.attributeName === 'class') {
          updateGiscusTheme();
        }
      }
    });
    observer.observe(document.documentElement, { attributes: true });
    signal.addEventListener('abort', () => observer.disconnect(), { once: true });
    document.addEventListener('astro:after-swap', updateGiscusTheme, { signal });
    updateGiscusTheme();
  });
</script>
