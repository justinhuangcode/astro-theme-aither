---
import EmbeddedGalleryPage from '@/components/pages/EmbeddedGalleryPage.astro';
import { getPaginatedGallery } from '@/lib/gallery';
import { rootLocale } from '@/lib/route-helpers';

const { entries, categories, totalPages } = await getPaginatedGallery(rootLocale, 1);
---

<EmbeddedGalleryPage
  locale={rootLocale}
  entries={entries}
  categories={categories}
  currentPage={1}
  totalPages={totalPages}
/>
