---
import PostPage from '@/components/pages/PostPage.astro';
import { type Locale } from '@/i18n';
import { createLocalizedStaticPaths } from '@/lib/route-helpers';
import { getPostStaticPaths } from '@/lib/site-content';
import type { PostEntry } from '@/lib/posts';

export async function getStaticPaths() {
  return createLocalizedStaticPaths((locale) => getPostStaticPaths(locale));
}

const { locale, post, prevPost, nextPost } = Astro.props as {
  locale: Locale;
  post: PostEntry;
  prevPost: PostEntry | null;
  nextPost: PostEntry | null;
};
---

<PostPage locale={locale} post={post} prevPost={prevPost} nextPost={nextPost} />
