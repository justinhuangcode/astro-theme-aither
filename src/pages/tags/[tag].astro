---
import PostsTaxonomyPage from '@/components/pages/PostsTaxonomyPage.astro';
import { getPostTagArchives } from '@/lib/post-taxonomy';
import { rootLocale } from '@/lib/route-helpers';

export async function getStaticPaths() {
  const archives = await getPostTagArchives(rootLocale);

  return archives.map((archive) => ({
    params: { tag: archive.slug },
    props: {
      title: `#${archive.label}`,
      description: `Posts tagged ${archive.label}.`,
      posts: archive.posts,
    },
  }));
}

const { title, description, posts } = Astro.props as {
  title: string;
  description: string;
  posts: Awaited<ReturnType<typeof getPostTagArchives>>[number]['posts'];
};
---

<PostsTaxonomyPage locale={rootLocale} title={title} description={description} posts={posts} />
