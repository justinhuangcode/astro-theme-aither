---
import PostPage from '@/components/pages/PostPage.astro';
import { getPostStaticPaths } from '@/lib/site-content';
import { createRootStaticPaths, rootLocale } from '@/lib/route-helpers';

export const getStaticPaths = createRootStaticPaths(getPostStaticPaths);

const { post, prevPost, nextPost } = Astro.props;
---

<PostPage locale={rootLocale} post={post} prevPost={prevPost} nextPost={nextPost} />
