{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx"
  },
  "exclude": [
    "dist",
    "output",
    ".references",
    ".playwright-cli",
    "public/pagefind/**/*.js",
    "public/directory/ui/js/**/*.js"
  ]
}
